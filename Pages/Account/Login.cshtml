@page
@model GuildApp.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Вход — Гильдия</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-dark">
    <div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
        <div class="card shadow" style="width:360px">
            <div class="card-body p-4">
                <h4 class="card-title text-center mb-4">⚔️ Гильдия</h4>
                <form method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Имя пользователя</label>
                        <input asp-for="Username" class="form-control" autocomplete="username" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Войти</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
