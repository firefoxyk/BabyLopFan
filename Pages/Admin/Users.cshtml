@page
@model GuildApp.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Управление пользователями";
}

<h2>Управление пользователями</h2>

@if (Model.StatusMessage != null)
{
    <div class="alert alert-info alert-dismissible fade show">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header fw-bold">Создать нового пользователя</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Create">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="NewUsername" class="form-label">Имя пользователя</label>
                    <input asp-for="NewUsername" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="NewGuildNickname" class="form-label">Никнейм в гильдии</label>
                    <input asp-for="NewGuildNickname" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="NewPassword" class="form-label">Пароль</label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="NewRole" class="form-label">Роль</label>
                    <select asp-for="NewRole" class="form-select">
                        <option value="Member">Участник</option>
                        <option value="Admin">Администратор</option>
                    </select>
                </div>
            </div>
            <div asp-validation-summary="All" class="text-danger mt-2"></div>
            <button type="submit" class="btn btn-primary mt-3">Создать пользователя</button>
        </form>
    </div>
</div>

<h4>Список пользователей</h4>
<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Имя пользователя</th>
            <th>Никнейм в гильдии</th>
            <th>Роль</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model.Users)
        {
            <tr class="@(!u.IsActive ? "table-secondary text-muted" : "")">
                <td>@u.UserName</td>
                <td>@u.GuildNickname</td>
                <td>@u.Role</td>
                <td>
                    @if (u.IsActive)
                    {
                        <span class="badge bg-success">Активен</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Деактивирован</span>
                    }
                </td>
                <td>
                    @if (u.IsActive && u.UserName != User.Identity!.Name)
                    {
                        <form method="post" asp-page-handler="Deactivate" style="display:inline">
                            <input type="hidden" name="userId" value="@u.Id" />
                            <button type="submit" class="btn btn-warning btn-sm"
                                    onclick="return confirm('Деактивировать пользователя @u.UserName?')">
                                Деактивировать
                            </button>
                        </form>
                    }
                    @if (!u.IsActive)
                    {
                        <form method="post" asp-page-handler="Activate" style="display:inline">
                            <input type="hidden" name="userId" value="@u.Id" />
                            <button type="submit" class="btn btn-success btn-sm">Активировать</button>
                        </form>
                    }
                    @if (u.UserName == User.Identity!.Name)
                    {
                        <span class="text-muted small">— это вы</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
