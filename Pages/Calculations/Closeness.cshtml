@page
@model GuildApp.Pages.Calculations.ClosenessModel
@using System.Globalization
@{
    ViewData["Title"] = "Близость";

    var ru = new CultureInfo("ru-RU");

    string Fmt(long n) => n.ToString("N0", ru);
}

<style>
    .hunt-table {
        border-collapse: collapse;
        font-size: 12px;
        width: 100%;
    }

        .hunt-table th,
        .hunt-table td {
            border: 1px solid #999;
            padding: 2px 5px;
            white-space: nowrap;
        }

        .hunt-table th {
            background: #dce6f1;
            text-align: center;
            font-weight: 600;
        }

        .hunt-table td {
            text-align: right;
        }

            .hunt-table td.td-left {
                text-align: left;
            }

            .hunt-table td.td-center {
                text-align: center;
            }

    .btn-hunt {
        padding: 3px 12px;
        font-size: 12px;
        cursor: pointer;
        border: 1px solid #666;
        background: #f0f0f0;
        white-space: nowrap;
    }

    .btn-hunt-primary {
        background: #4472c4;
        color: #fff;
        border-color: #2a52a4;
    }

    .inf-input {
        width: 160px;
        font-size: 12px;
        padding: 2px 5px;
        border: 1px solid #999;
        text-align: right;
    }

    .closeness-layout {
        display: flex;
        align-items: flex-start;
        gap: 18px;
        flex-wrap: wrap;
    }

    .closeness-panel {
        flex: 0 0 auto;
    }

    .closeness-panel-left {
        width: 540px;
        max-width: 100%;
    }

    .closeness-panel-right {
        width: 430px;
        max-width: 100%;
    }

    .closeness-panel-wide {
        width: 988px;
        max-width: 100%;
        margin-top: 18px;
    }

    .block-header-row {
        background: #c9b47a !important;
        padding: 0 !important;
    }

    .block-subheader-row {
        background: #efe6c6 !important;
        padding: 0 !important;
    }

    .header-flex {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 8px;
        text-align: left;
    }

    .header-flex-left {
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        flex: 1 1 auto;
        text-align: left;
        justify-content: flex-start;
    }

    .header-title-text {
        font-weight: 700;
        font-size: 14px;
        text-align: left;
        white-space: normal;
    }

    .subheader-title-text {
        font-weight: 700;
        font-size: 12px;
        text-align: left;
        white-space: normal;
    }

    .closeness-name {
        text-align: left !important;
        font-weight: 600;
        white-space: normal !important;
        word-break: keep-all;
    }

    .closeness-input-cell {
        text-align: center !important;
    }

    .closeness-input {
        width: 90px;
    }

    .estate-input {
        width: 86px;
    }

    .closeness-range {
        font-weight: 600;
    }

    .summary-row td {
        background: #e4dfec;
        font-weight: 700;
    }

    .summary-name {
        text-align: left !important;
        white-space: normal !important;
    }

    .summary-code {
        text-align: center !important;
        width: 90px;
    }

    .separator-top td {
        border-top: 3px solid #666 !important;
    }

    .radio-wrap {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
        white-space: nowrap;
    }

    .radio-option {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .value-cell {
        font-weight: 700;
    }

    .tooltip-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
    }

    .tooltip-trigger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 16px;
        height: 16px;
        border: 1px solid #666;
        border-radius: 50%;
        font-size: 11px;
        line-height: 1;
        cursor: pointer;
        background: #f8f8f8;
        user-select: none;
        flex: 0 0 auto;
    }

    .tooltip-box {
        position: absolute;
        top: 22px;
        left: 0;
        width: 280px;
        background: #fffef7;
        border: 1px solid #999;
        box-shadow: 0 2px 8px rgba(0,0,0,.12);
        padding: 8px 10px;
        text-align: left;
        white-space: normal;
        z-index: 20;
        font-size: 12px;
    }

        .tooltip-box.hidden {
            display: none;
        }

    .estate-table {
        font-size: 11.5px;
    }

        .estate-table th,
        .estate-table td {
            padding: 3px 5px;
        }

    .estate-left {
        text-align: left !important;
        white-space: normal !important;
        font-weight: 600;
        background: #f7f7f7;
    }

    .estate-section {
        background: #8e7cc3 !important;
        color: #000;
        font-weight: 700 !important;
        font-size: 14px;
    }

    .estate-group {
        background: #d9d2e9 !important;
        font-weight: 700 !important;
    }

    .estate-result {
        font-weight: 700;
        background: #f4f1fb;
    }

    .deep-level-row td {
        background: #fcfcff;
    }

    .deep-level-row-theater td {
        background: #f3eefb;
    }

    .deep-level-row-antique td {
        background: #eef7ee;
    }

    .deep-positive {
        color: #2e7d32;
        font-weight: 600;
    }

    .deep-negative {
        color: #c62828;
        font-weight: 600;
    }

    .deep-neutral {
        color: inherit;
    }

    .deep-x {
        color: #555;
        font-weight: 600;
    }

    .deep-hidden {
        color: transparent;
    }

    .deep-total {
        font-weight: 600;
    }

    .deep-summary-row td {
        background: rgba(255, 255, 255, 0.25);
    }

    .page-title {
        margin-bottom: 16px;
    }

    .history-table {
        margin-top: 20px;
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

        .history-table th,
        .history-table td {
            border: 1px solid #999;
            padding: 4px 6px;
        }

        .history-table th {
            background: #d9e2f3;
            text-align: center;
        }

    .saved-message {
        color: #2e7d32;
        font-weight: 700;
        margin-top: 8px;
    }
</style>

<h2 class="page-title">Близость</h2>

<div class="closeness-layout">
    <div class="closeness-panel closeness-panel-left">
        <form method="post" asp-page-handler="CalculateCloseness">
            <table class="hunt-table">
                <tr>
                    <th colspan="5" class="block-header-row">
                        <div class="header-flex">
                            <div class="header-flex-left">
                                <span class="header-title-text">Расчет количества очков близости</span>
                            </div>
                            <button type="submit" class="btn-hunt btn-hunt-primary">Рассчитать</button>
                        </div>
                    </th>
                </tr>
                <tr>
                    <th class="td-left">Предмет</th>
                    <th>Количество</th>
                    <th>Мин</th>
                    <th>Макс</th>
                    <th>Среднее</th>
                </tr>
                <tr>
                    <td class="closeness-name">Белый нефрит</td>
                    <td class="closeness-input-cell"><input asp-for="WhiteJadeCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.WhiteJadeValue)</td>
                    <td>@Fmt(Model.WhiteJadeValue)</td>
                    <td>@Fmt(Model.WhiteJadeValue)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Агатовый нефрит</td>
                    <td class="closeness-input-cell"><input asp-for="AgateJadeCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.AgateJadeValue)</td>
                    <td>@Fmt(Model.AgateJadeValue)</td>
                    <td>@Fmt(Model.AgateJadeValue)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Хотанский нефрит</td>
                    <td class="closeness-input-cell"><input asp-for="HotanJadeCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.HotanJadeValue)</td>
                    <td>@Fmt(Model.HotanJadeValue)</td>
                    <td>@Fmt(Model.HotanJadeValue)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Манговый нектар</td>
                    <td class="closeness-input-cell"><input asp-for="MangoNectarCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.MangoNectarValue)</td>
                    <td>@Fmt(Model.MangoNectarValue)</td>
                    <td>@Fmt(Model.MangoNectarValue)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Промо-предметы</td>
                    <td class="closeness-input-cell"><input asp-for="PromoItemsCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.PromoItemsValue)</td>
                    <td>@Fmt(Model.PromoItemsValue)</td>
                    <td>@Fmt(Model.PromoItemsValue)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Мешки близости</td>
                    <td class="closeness-input-cell"><input asp-for="ClosenessBagsCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.BagsMinValue)</td>
                    <td>@Fmt(Model.BagsMaxValue)</td>
                    <td>@Fmt((Model.BagsMinValue + Model.BagsMaxValue) / 2)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Рисовые шарики</td>
                    <td class="closeness-input-cell"><input asp-for="RiceBallCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.RiceMinValue)</td>
                    <td>@Fmt(Model.RiceMaxValue)</td>
                    <td>@Fmt((Model.RiceMinValue + Model.RiceMaxValue) / 2)</td>
                </tr>
                <tr>
                    <td class="closeness-name">Волшебный горшочек</td>
                    <td class="closeness-input-cell"><input asp-for="FairyPotCount" class="inf-input closeness-input" /></td>
                    <td>@Fmt(Model.PotMinValue)</td>
                    <td>@Fmt(Model.PotMaxValue)</td>
                    <td>@Fmt((Model.PotMinValue + Model.PotMaxValue) / 2)</td>
                </tr>
                <tr class="summary-row separator-top">
                    <td class="summary-name">Итого</td>
                    <td class="summary-code">Без поместья</td>
                    <td>@Fmt(Model.MinTotal)</td>
                    <td>@Fmt(Model.MaxTotal)</td>
                    <td>@Fmt(Model.AverageTotal)</td>
                </tr>
                <tr class="summary-row">
                    <td class="summary-name">Итого</td>
                    <td class="summary-code">С поместьем</td>
                    <td>@Fmt(Model.MinWithEstate)</td>
                    <td>@Fmt(Model.MaxWithEstate)</td>
                    <td>@Fmt(Model.AverageWithEstate)</td>
                </tr>
            </table>
        </form>
    </div>

    <div class="closeness-panel closeness-panel-right">
        <form method="post" asp-page-handler="CalculatePhysical">
            <table class="hunt-table">
                <tr>
                    <th colspan="2" class="block-header-row">
                        <div class="header-flex">
                            <div class="header-flex-left">
                                <span class="header-title-text">Пытаемся посчитать по теории вероятности опыт близости за трату шаров физ. силы</span>
                            </div>
                            <button type="submit" class="btn-hunt btn-hunt-primary">Рассчитать</button>
                        </div>
                    </th>
                </tr>
                <tr>
                    <td class="closeness-name">Полный пропуск</td>
                    <td class="closeness-input-cell"><input asp-for="HasFullPass" type="checkbox" /></td>
                </tr>
                <tr>
                    <td class="closeness-name">Месячный пропуск</td>
                    <td class="closeness-input-cell"><input asp-for="HasMonthPass" type="checkbox" /></td>
                </tr>
                <tr>
                    <td class="closeness-name">Количество друзей Пэнлай</td>
                    <td class="closeness-input-cell"><input asp-for="PenglaiFriendsCount" class="inf-input closeness-input" /></td>
                </tr>
                <tr>
                    <td class="closeness-name">Открыта Шэнь Линхуа</td>
                    <td class="closeness-input-cell"><input asp-for="IsShenLinghuaOpened" type="checkbox" /></td>
                </tr>
                <tr>
                    <td class="closeness-name">Количество шаров физ. силы</td>
                    <td class="closeness-input-cell"><input asp-for="PhysicalPowerBallsCount" class="inf-input closeness-input" /></td>
                </tr>
                <tr class="summary-row separator-top">
                    <td class="summary-name">Шанс обычного города, %</td>
                    <td>@Fmt(Model.RegularCityChancePercent)</td>
                </tr>
                <tr class="summary-row">
                    <td class="summary-name">Шанс Пэнлай, %</td>
                    <td>@Fmt(Model.PenglaiChancePercent)</td>
                </tr>
                <tr class="summary-row">
                    <td class="summary-name">Близость обычный город</td>
                    <td>@Fmt(Model.RegularCityCloseness)</td>
                </tr>
                <tr class="summary-row">
                    <td class="summary-name">Близость Пэнлай</td>
                    <td>@Fmt(Model.PenglaiCloseness)</td>
                </tr>
                <tr class="summary-row">
                    <td class="summary-name">Итого близости</td>
                    <td>@Fmt(Model.PhysicalPowerTotalCloseness)</td>
                </tr>
            </table>
        </form>
    </div>
</div>

<div class="closeness-panel closeness-panel-wide">
    <form method="post" asp-page-handler="CalculateEstateBuilding">
        <table class="hunt-table estate-table">
            <tr>
                <th colspan="13" class="block-header-row">
                    <div class="header-flex">
                        <div class="header-flex-left">
                            <span class="header-title-text">Заполнение информации по зданию</span>
                        </div>
                        <button type="submit" class="btn-hunt btn-hunt-primary">Рассчитать</button>
                    </div>
                </th>
            </tr>
            <tr>
                <th class="estate-left">Наименование</th>
                <th>Вышивка</th>
                <th>Фарфор</th>
                <th>Свиток</th>
                <th>Нефритовое украшение</th>
                <th>Хлыст</th>
                <th>Веер Солнца и Луны</th>
                <th>Шляпа Вэньян</th>
                <th>Маска</th>
            </tr>
            <tr>
                <td class="estate-left">Производство в минуту</td>
                <td><input asp-for="AntiqueEmbroideryProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiquePorcelainProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueScrollProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueJadeDecorationProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterWhipProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterFanProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterHatProductionPerMinute" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterMaskProductionPerMinute" class="inf-input estate-input" /></td>
            </tr>
            <tr>
                <td class="estate-left">В наличии сейчас</td>
                <td><input asp-for="AntiqueEmbroideryCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiquePorcelainCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueScrollCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueJadeDecorationCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterWhipCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterFanCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterHatCurrentAmount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterMaskCurrentAmount" class="inf-input estate-input" /></td>
            </tr>
            <tr>
                <td class="estate-left">Через 1 день</td>
                <td>@Fmt(Model.AntiqueEmbroideryCurrentPlusDay)</td>
                <td>@Fmt(Model.AntiquePorcelainCurrentPlusDay)</td>
                <td>@Fmt(Model.AntiqueScrollCurrentPlusDay)</td>
                <td>@Fmt(Model.AntiqueJadeDecorationCurrentPlusDay)</td>
                <td>@Fmt(Model.TheaterWhipCurrentPlusDay)</td>
                <td>@Fmt(Model.TheaterFanCurrentPlusDay)</td>
                <td>@Fmt(Model.TheaterHatCurrentPlusDay)</td>
                <td>@Fmt(Model.TheaterMaskCurrentPlusDay)</td>
            </tr>
            <tr>
                <td class="estate-left">Через 47 дней</td>
                <td>@Fmt(Model.AntiqueEmbroideryCurrentPlus47Days)</td>
                <td>@Fmt(Model.AntiquePorcelainCurrentPlus47Days)</td>
                <td>@Fmt(Model.AntiqueScrollCurrentPlus47Days)</td>
                <td>@Fmt(Model.AntiqueJadeDecorationCurrentPlus47Days)</td>
                <td>@Fmt(Model.TheaterWhipCurrentPlus47Days)</td>
                <td>@Fmt(Model.TheaterFanCurrentPlus47Days)</td>
                <td>@Fmt(Model.TheaterHatCurrentPlus47Days)</td>
                <td>@Fmt(Model.TheaterMaskCurrentPlus47Days)</td>
            </tr>
            <tr>
                <td class="estate-left">Количество дней</td>
                <td><input asp-for="AntiqueEmbroideryDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiquePorcelainDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueScrollDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueJadeDecorationDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterWhipDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterFanDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterHatDaysCount" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterMaskDaysCount" class="inf-input estate-input" /></td>
            </tr>
            <tr>
                <td class="estate-left">Через N дней</td>
                <td>@Fmt(Model.AntiqueEmbroideryCurrentPlusNDays)</td>
                <td>@Fmt(Model.AntiquePorcelainCurrentPlusNDays)</td>
                <td>@Fmt(Model.AntiqueScrollCurrentPlusNDays)</td>
                <td>@Fmt(Model.AntiqueJadeDecorationCurrentPlusNDays)</td>
                <td>@Fmt(Model.TheaterWhipCurrentPlusNDays)</td>
                <td>@Fmt(Model.TheaterFanCurrentPlusNDays)</td>
                <td>@Fmt(Model.TheaterHatCurrentPlusNDays)</td>
                <td>@Fmt(Model.TheaterMaskCurrentPlusNDays)</td>
            </tr>
        </table>
    </form>
</div>

<div class="closeness-panel closeness-panel-wide">
    <form method="post" asp-page-handler="CalculateDeepFeelings">
        <table class="hunt-table estate-table">
            <tr>
                <th colspan="9" class="block-header-row">
                    <div class="header-flex">
                        <div class="header-flex-left">
                            <span class="header-title-text">Расходы глубоких чувств</span>
                        </div>
                        <button type="submit" class="btn-hunt btn-hunt-primary">Рассчитать</button>
                    </div>
                </th>
            </tr>

            <tr>
                <th colspan="5" class="estate-section">Театр</th>
                <th colspan="4" class="estate-section">Антикварная лавка</th>
            </tr>

            <tr>
                <th class="estate-left">Наименование</th>
                <th>Хлыст</th>
                <th>Веер Солнца и Луны</th>
                <th>Шляпа Вэньян</th>
                <th>Маска</th>
                <th>Вышивка</th>
                <th>Фарфор</th>
                <th>Свиток</th>
                <th>Нефритовое украшение</th>
            </tr>

            <tr>
                <td class="estate-left">Текущий уровень глубоких чувств</td>
                <td><input asp-for="TheaterWhipDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterFanDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterHatDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterMaskDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueEmbroideryDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiquePorcelainDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueScrollDeepLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueJadeDecorationDeepLevel" class="inf-input estate-input" /></td>
            </tr>

            <tr>
                <td class="estate-left">Ресурсы для траты</td>
                <td><input asp-for="TheaterWhipSpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterFanSpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterHatSpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterMaskSpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueEmbroiderySpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiquePorcelainSpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueScrollSpendResource" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueJadeDecorationSpendResource" class="inf-input estate-input" /></td>
            </tr>

            <tr>
                <td class="estate-left">Количество близких друзей</td>
                <td><input asp-for="TheaterWhipBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterFanBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterHatBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="TheaterMaskBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueEmbroideryBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiquePorcelainBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueScrollBonusLevel" class="inf-input estate-input" /></td>
                <td><input asp-for="AntiqueJadeDecorationBonusLevel" class="inf-input estate-input" /></td>
            </tr>

            @if (Model.ShowDeepFeelingsResults)
            {
                var theaterRowsCount = Model.TheaterDeepResult.Rows.Count;
                var antiqueRowsCount = Model.AntiqueDeepResult.Rows.Count;
                var maxRowsCount = Math.Max(theaterRowsCount, antiqueRowsCount);

                for (var i = 0; i < maxRowsCount; i++)
                {
                    var theaterRow = i < theaterRowsCount ? Model.TheaterDeepResult.Rows[i] : null;
                    var antiqueRow = i < antiqueRowsCount ? Model.AntiqueDeepResult.Rows[i] : null;

                    <tr>
                        <td class="estate-left">
                            @if (theaterRow != null)
                            {
                                @($"{theaterRow.LevelNumber} уровень")
                            }
                            else if (antiqueRow != null)
                            {
                                @($"{antiqueRow.LevelNumber} уровень")
                            }
                        </td>

                        @if (theaterRow != null)
                        {
                            <td class="@theaterRow.Cells[0].CssClass">@theaterRow.Cells[0].DisplayText</td>
                            <td class="@theaterRow.Cells[1].CssClass">@theaterRow.Cells[1].DisplayText</td>
                            <td class="@theaterRow.Cells[2].CssClass">@theaterRow.Cells[2].DisplayText</td>
                            <td class="@theaterRow.Cells[3].CssClass">@theaterRow.Cells[3].DisplayText</td>
                        }
                        else
                        {
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        }

                        @if (antiqueRow != null)
                        {
                            <td class="@antiqueRow.Cells[0].CssClass">@antiqueRow.Cells[0].DisplayText</td>
                            <td class="@antiqueRow.Cells[1].CssClass">@antiqueRow.Cells[1].DisplayText</td>
                            <td class="@antiqueRow.Cells[2].CssClass">@antiqueRow.Cells[2].DisplayText</td>
                            <td class="@antiqueRow.Cells[3].CssClass">@antiqueRow.Cells[3].DisplayText</td>
                        }
                        else
                        {
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        }
                    </tr>
                }

                <tr class="deep-summary-row">
                    <td class="estate-left">Всего уровней</td>
                    <td class="deep-total">@Model.TheaterDeepResult.TotalLevels[0]</td>
                    <td class="deep-total">@Model.TheaterDeepResult.TotalLevels[1]</td>
                    <td class="deep-total">@Model.TheaterDeepResult.TotalLevels[2]</td>
                    <td class="deep-total">@Model.TheaterDeepResult.TotalLevels[3]</td>
                    <td class="deep-total">@Model.AntiqueDeepResult.TotalLevels[0]</td>
                    <td class="deep-total">@Model.AntiqueDeepResult.TotalLevels[1]</td>
                    <td class="deep-total">@Model.AntiqueDeepResult.TotalLevels[2]</td>
                    <td class="deep-total">@Model.AntiqueDeepResult.TotalLevels[3]</td>
                </tr>

                <tr class="deep-summary-row">
                    <td class="estate-left">Близости</td>
                    <td class="deep-total">@Fmt(Model.TheaterDeepResult.ClosenessValues[0])</td>
                    <td class="deep-total">@Fmt(Model.TheaterDeepResult.ClosenessValues[1])</td>
                    <td class="deep-total">@Fmt(Model.TheaterDeepResult.ClosenessValues[2])</td>
                    <td class="deep-total">@Fmt(Model.TheaterDeepResult.ClosenessValues[3])</td>
                    <td class="deep-total">@Fmt(Model.AntiqueDeepResult.ClosenessValues[0])</td>
                    <td class="deep-total">@Fmt(Model.AntiqueDeepResult.ClosenessValues[1])</td>
                    <td class="deep-total">@Fmt(Model.AntiqueDeepResult.ClosenessValues[2])</td>
                    <td class="deep-total">@Fmt(Model.AntiqueDeepResult.ClosenessValues[3])</td>
                </tr>
            }
        </table>
    </form>
</div>

<script>
    (function () {
        const storageKey = 'closeness-page-state';
        const selector = 'input[name], select[name], textarea[name]';

        function getFields() {
            return Array.from(document.querySelectorAll(selector)).filter(function (field) {
                return field.name !== '__RequestVerificationToken'
                    && !field.classList.contains('js-page-state-hidden');
            });
        }

        function loadState() {
            try {
                return JSON.parse(sessionStorage.getItem(storageKey) || '{}');
            } catch {
                return {};
            }
        }

        function saveState() {
            const state = {};

            for (const field of getFields()) {
                if (field.type === 'checkbox') {
                    state[field.name] = field.checked;
                    continue;
                }

                if (field.type === 'radio') {
                    if (field.checked) {
                        state[field.name] = field.value;
                    }
                    continue;
                }

                state[field.name] = field.value;
            }

            sessionStorage.setItem(storageKey, JSON.stringify(state));
        }

        function appendPageStateToForm(form) {
            form.querySelectorAll('.js-page-state-hidden').forEach(function (item) {
                item.remove();
            });

            const fields = getFields();

            for (const field of fields) {
                if (!field.name) {
                    continue;
                }

                if (form.contains(field)) {
                    continue;
                }

                if (field.type === 'radio' && !field.checked) {
                    continue;
                }

                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field.name;
                hidden.className = 'js-page-state-hidden';

                if (field.type === 'checkbox') {
                    hidden.value = field.checked ? 'true' : 'false';
                } else {
                    hidden.value = field.value ?? '';
                }

                form.appendChild(hidden);
            }

            const showDeepFeelingsResults = document.createElement('input');
            showDeepFeelingsResults.type = 'hidden';
            showDeepFeelingsResults.name = 'ShowDeepFeelingsResults';
            showDeepFeelingsResults.value = @Html.Raw(Model.ShowDeepFeelingsResults ? "'true'" : "'false'");
            showDeepFeelingsResults.className = 'js-page-state-hidden';
            form.appendChild(showDeepFeelingsResults);
        }

        function restoreState() {
            const state = loadState();

            for (const field of getFields()) {
                if (!(field.name in state)) {
                    continue;
                }

                if (field.type === 'checkbox') {
                    field.checked = !!state[field.name];
                    continue;
                }

                if (field.type === 'radio') {
                    field.checked = state[field.name] === field.value;
                    continue;
                }

                if (!field.value) {
                    field.value = state[field.name] ?? '';
                }
            }
        }

        document.addEventListener('input', function (event) {
            if (event.target && event.target.matches(selector)) {
                saveState();
            }
        });

        document.addEventListener('change', function (event) {
            if (event.target && event.target.matches(selector)) {
                saveState();
            }
        });

        document.addEventListener('submit', function (event) {
            if (event.target && event.target.matches('form')) {
                saveState();
                appendPageStateToForm(event.target);
            }
        }, true);

        restoreState();
        saveState();
    })();
</script>
